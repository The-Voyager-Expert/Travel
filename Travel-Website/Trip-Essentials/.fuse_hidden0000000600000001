<script>
(function () {
  var pills = document.getElementById('view-pills');
  pills.addEventListener('click', function (e) {
    var pill = e.target.closest('.view-pill');
    if (!pill) return;
    var viewId = pill.dataset.view;
    pills.querySelectorAll('.view-pill').forEach(function (p) { p.classList.remove('active'); });
    document.querySelectorAll('.view').forEach(function (v) { v.classList.remove('active'); });
    pill.classList.add('active');
    var view = document.getElementById('view-' + viewId);
    if (view) view.classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
}());
</script>
