<title>Planning Resources</title>
<style>
:root {
  --bg:      #f5f4f0;
  --warm:    #fdf8f0;
  --surface: #ffffff;
  --border:  #d8d4cc;
  --border2: #e6e2da;
  --text:    #1a1917;
  --muted:   #6a6660;
  --accent:  #8a6c1a;
  --hover:   #faefd8;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Apple Color Emoji', 'Segoe UI Emoji', Arial, sans-serif;
  font-size: 14px;
  line-height: 1.6;
  min-height: 100vh;
  padding-bottom: 80px;
}
.wrap { max-width: 940px; margin: 0 auto; padding: 0 24px; }

/* ── Page header ── */
.page-header {
  background: linear-gradient(135deg, #7a3b1e 0%, #b85c2a 55%, #d4874a 100%);
  padding: 14px 18px;
  border-radius: 10px;
  border-bottom: none;
  margin: 8px 0 14px;
}
.eyebrow {
  font-size: 12px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 8px;
}
.page-header h1 {
  font-size: 14px;
  font-weight: bold;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  line-height: 1.2;
  margin: 0;
}
.page-header p { font-size: 12px; color: rgba(255,255,255,0.72); margin-top: 4px; }

/* ── View toggle (Quick Launch / Visa Check) ── */
.view-pills {
  display: flex;
  gap: 4px;
  margin: 16px 0 20px;
  padding-left: 2px;
}
.view-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: transparent;
  border: 1px solid transparent;
  border-radius: 999px;
  padding: 6px 14px;
  font-size: 12.5px;
  color: #3d3a32;
  cursor: pointer;
  text-decoration: none;
  transition: background .15s, color .15s, border-color .15s;
  white-space: nowrap;
  user-select: none;
  font-family: inherit;
}
.view-pill:hover { background: rgba(138,108,26,.06); color: var(--accent); }
.view-pill.active {
  background: rgba(138,108,26,.10);
  color: var(--accent);
  border-color: rgba(138,108,26,.25);
  font-weight: 500;
}

/* ── Views ── */
.view { display: none; }
.view.active { display: block; }

/* ── Quick Launch — speed-dial of booking shortcuts ── */
.launch-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(255px, 1fr));
  gap: 18px 24px;
  align-items: start;
}
.cat-block { break-inside: avoid; }
.cat-head {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--border2);
}
.cat-head .ch-emoji { font-size: 15px; line-height: 1; letter-spacing: 0; }
.chips-wrap { display: flex; flex-wrap: wrap; gap: 6px; }
a.chip-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 11px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 13px;
  color: var(--text);
  text-decoration: none;
  line-height: 1.3;
  transition: border-color .15s, background .15s, color .15s, box-shadow .15s;
}
a.chip-link:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--hover);
  box-shadow: 0 1px 5px rgba(138,108,26,.12);
}
a.chip-link .ci { font-size: 14px; line-height: 1; flex-shrink: 0; }
.launch-note {
  font-size: 12px;
  color: var(--muted);
  margin: 0 0 18px;
  line-height: 1.5;
}

/* ── Mobile ── */
@media (max-width: 600px) {
  .launch-grid { grid-template-columns: 1fr; gap: 16px; }
  a.chip-link { font-size: 13px; padding: 7px 12px; }
}

/* ── Visa Check view ── */
.visa-src { display: flex; justify-content: flex-end; margin: 0 0 12px; }
.visa-src a { font-size: 12px; font-weight: 600; color: var(--accent); text-decoration: none; }
.legend { display: flex; flex-wrap: wrap; gap: 7px; margin: 0 0 18px; }
.legend .pill { display: inline-flex; align-items: center; gap: 6px; padding: 5px 11px;
  background: var(--warm); border: 1px solid var(--border2); border-radius: 16px; font-size: 11px; color: var(--muted); line-height: 1; }
.dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
.d-vf{background:#2a6a2a} .d-card{background:#1a5f8b} .d-eta{background:#b5731a}
.d-evisa{background:#6b3fa0} .d-voa{background:#0f7d7d} .d-visa{background:#b3402a}
.etype { background: var(--surface); border: 1px solid var(--border); border-left: 4px solid var(--ec,#999);
  border-radius: 8px; padding: 16px 20px 18px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(92,61,17,0.06); }
.etype.vf{--ec:#2a6a2a} .etype.card{--ec:#1a5f8b} .etype.eta{--ec:#b5731a}
.etype.evisa{--ec:#6b3fa0} .etype.voa{--ec:#0f7d7d} .etype.visa{--ec:#b3402a}
.etype-head { display: flex; align-items: baseline; flex-wrap: wrap; gap: 8px; margin-bottom: 4px; }
.etype-title { font-size: 14px; font-weight: 700; color: var(--ec); }
.etype-count { font-size: 11px; color: var(--muted); margin-left: auto; font-variant-numeric: tabular-nums; }
.etype-desc { font-size: 12px; color: var(--muted); margin-bottom: 12px; line-height: 1.5; }
.enote { font-size: 12px; color: #5C3D11; background: #fbf3e2; border: 1px solid #ecdcbb;
  border-radius: 6px; padding: 9px 12px; margin: 0 0 12px; line-height: 1.5; }
.enote b { color: #7a3b1e; }
.chips { display: flex; flex-wrap: wrap; gap: 7px; }
.chip { display: inline-flex; align-items: baseline; gap: 7px; padding: 6px 11px; background: var(--warm);
  border: 1px solid var(--border2); border-radius: 7px; font-size: 14px; white-space: nowrap; }
.chip .lim { font-size: 11px; color: var(--muted); font-variant-numeric: tabular-nums; }
.rows { display: flex; flex-direction: column; gap: 9px; }
.row { display: flex; flex-wrap: wrap; align-items: baseline; gap: 4px 10px; padding: 10px 12px;
  background: var(--warm); border: 1px solid var(--border2); border-radius: 7px; }
.row .cty { font-size: 14px; font-weight: 600; min-width: 150px; }
.row .lim { font-size: 11px; color: #2a6a2a; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
.row .rnote { flex: 1 1 100%; font-size: 12px; color: var(--muted); line-height: 1.5; }
.visa-foot { font-size: 11px; color: var(--muted); margin: 16px 0 0; padding-top: 12px; border-top: 1px solid var(--border); }
.visa-foot b { color: var(--text); }
@media (max-width: 600px) { .row .cty { min-width: 0; } .etype { padding: 14px 14px 16px; } }
</style>
