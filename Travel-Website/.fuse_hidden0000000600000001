/* ─── RESPONSIVE (mobile — Dani reads on her iPhone) ───────────────────────── */
/* Per Rules for Claude.html § 8: PDF rendered at 500px viewport
   so the mobile @media block fires; fonts hit 21px body / 24px stop names /
   25px section titles.
   ALL text scales UP from the desktop baseline (15px → 21px), not down.
   Smaller viewports need larger glyphs — physical pixel density and
   hand-held reading distance make 15px illegible on a phone. To adjust
   overall scale, change `body { font-size }` here; everything else follows. */
@media (max-width: 600px) {
  body         { font-size: 20px; line-height: 1.55; }
  .container   { padding: 0 14px 32px; }

  .title-page    { padding: 12px 16px 16px; margin-bottom: 14px; }
  .title-city    { font-size: 22px; }
  .title-hotel   { font-size: 16px; }
  .title-address { font-size: 13px; }

  .glance-section,
  .day-block,
  .extras-section,
  .claude-inspiration { padding: 20px 18px; margin-bottom: 16px; }

  .glance-title   { font-size: 18px; }
  .day-header     { font-size: 18px; }
  .extras-title   { font-size: 21px; }
  /* All Extras-section subtitles share the same size on mobile — uniform
     hierarchy across Cappuccino / Restaurants Near Hotel / Downtown / Local Tastes /
     Shows / Getting Around / Stations / Day Trips / Michelin / Pickleball /
     Food Delivery / Weekly Closures. (Locked 2026-05-19 per Dani.) */
  .extras-sub          { font-size: 18px; }

  .glance-day        { padding: 10px 14px; }
  .glance-day-title  { font-size: 16px; }
  .glance-day-stops  { font-size: 15px; }
  .glance-extra-link { font-size: 15px; }

  .stop-num,
  .stop-name { font-size: 19px; }
  .stop-row  { font-size: 18px; }

  .stop-photos { flex-direction: column; }
  /* `flex: none` RESETS the desktop `flex: 1 1 0%`. Without this reset, tall
     portrait images render at their natural aspect ratio and the explicit
     `height` is silently ignored — `flex-basis: 0%` on a flex item overrides
     `height` in Chromium. Do not remove `flex: none`.
     Explicit height (not max-height) so object-fit: cover has a fixed box.
     290px = iPhone 4:3 landscape proportions (390px wide × 0.75 = 292 → 290px). */
  .stop-photos img { flex: none; width: 100%; height: 290px; object-fit: cover; }

  .tour-box,
  .ticket-box,
  .tour-meet,
  .entry-body,
  .shows-box,
  .transit-box,
  .hotel-first,
  .arrive-first,
  div.train,
  .next,
  .next-tram,
  .warn { padding: 10px 12px; font-size: 18px; }
  .tour-meet { margin-left: 8px; }
  /* .ride-apps mobile font-size retired 2026-05-19 along with the class. */
}


/* ─── PRINT (offline PDF — fallback for non-screen renders) ────────────────── */
/* render_pdf.py uses screen media, so this block is mainly for direct
   print-from-browser. Strips backgrounds, switches to monochrome links,
   ensures transit banners stay glued to their following stop. */
@media print {
  body            { background: #fff; color: #000; font-size: 11px; }
  .container      { max-width: 100%; padding: 0; }
  .title-page     { background: #fff; color: #000; border: 1px solid #ccc; }
  .title-address  { color: #444; }
  .glance-section,
  .day-block,
  .extras-section,
  .claude-inspiration { box-shadow: none; border: 1px solid #ddd; }
  /* break-inside: avoid lives at the base (see §PAGE-BREAK CONTROL). */
  a               { color: #000; text-decoration: underline; }
  .next,
  .next-tram      { break-after: avoid; page-break-after: avoid; }
}


/* Shows — Style A per-entry block (heading + shows-box body) (2026-05-19).
   Each show ships as `.extras-sub` heading + `.shows-box` body; the heading
   gets the shows-section periwinkle bg with top-rounded corners and the
   shows-box gets bottom-rounded corners — they merge into one card per show.
   Description, booking link, address, walk time all live INSIDE shows-box. */
#shows .extras-sub {
  background: var(--c-shows-bg);
  border-left: 3px solid var(--c-shows-border);
  border-radius: 4px 4px 0 0;
  padding: 10px 14px 0 14px;
  margin: 14px 0 0;
}
#shows .shows-box {
  background: var(--c-shows-bg);
  border-left-color: var(--c-shows-border);
  border-radius: 0 0 4px 4px;
  padding-top: 0;
  margin-top: 0;
  margin-bottom: 0;
}

/* Skip List — footnote at the very bottom of the guide. Small italic grey, no banner. */
#skip-list { background: none; border: none; box-shadow: none; padding: 0; margin: 36px 0 0 0; }
#skip-list .skip-list-note, .skip-list-note { font-size: 13px; font-style: italic; color: #999; line-height: 1.6; }


/* ─── GUIDE TOOLBAR (top navigation) ───────────────────────────────────────── */
/* Top-of-page toolbar with guide navigation (Index/Previous/Next) and Trip
   Essentials quick links. Two-section layout: navigation links on left,
   essentials on right. Theme colors inherited from guide's color scheme. */
.guide-toolbar {
  background: transparent;
  border-bottom: 1px solid var(--c-next-border);
  padding: 12px 0;
  margin-bottom: 36px;
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  align-items: center;
  justify-content: space-between;
}

.toolbar-nav,
.toolbar-essentials {
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}

.toolbar-nav a,
.toolbar-essentials a {
  padding: 6px 12px;
  border-radius: 4px;
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  border: 1px solid var(--c-title-bg);
  color: var(--c-title-bg);
  transition: all 0.15s ease;
  background-color: var(--c-page-bg);
  white-space: nowrap;
}

.toolbar-nav a:hover,
.toolbar-essentials a:hover {
  background-color: rgba(74, 15, 32, 0.1);
  color: var(--c-title-bg);
  border-color: var(--c-title-bg);
}

/* Theme-specific toolbar border + button colors */
.guide-toolbar.theme-purple   { border-bottom-color: #7030A0; }
.guide-toolbar.theme-purple .toolbar-nav a,
.guide-toolbar.theme-purple .toolbar-essentials a { color: #7030a0; border-color: #7030a0; }
.guide-toolbar.theme-purple .toolbar-nav a:hover,
.guide-toolbar.theme-purple .toolbar-essentials a:hover { background-color: rgba(112, 48, 160, 0.08); }

.guide-toolbar.theme-teal     { border-bottom-color: #1c8a99; }
.guide-toolbar.theme-teal .toolbar-nav a,
.guide-toolbar.theme-teal .toolbar-essentials a { color: #1c8a99; border-color: #1c8a99; }
.guide-toolbar.theme-teal .toolbar-nav a:hover,
.guide-toolbar.theme-teal .toolbar-essentials a:hover { background-color: rgba(28, 138, 153, 0.08); }

.guide-toolbar.theme-coral    { border-bottom-color: #c85a54; }
.guide-toolbar.theme-coral .toolbar-nav a,
.guide-toolbar.theme-coral .toolbar-essentials a { color: #c85a54; border-color: #c85a54; }
.guide-toolbar.theme-coral .toolbar-nav a:hover,
.guide-toolbar.theme-coral .toolbar-essentials a:hover { background-color: rgba(200, 90, 84, 0.08); }

.guide-toolbar.theme-pink     { border-bottom-color: #d4336c; }
.guide-toolbar.theme-pink .toolbar-nav a,
.guide-toolbar.theme-pink .toolbar-essentials a { color: #d4336c; border-color: #d4336c; }
.guide-toolbar.theme-pink .toolbar-nav a:hover,
.guide-toolbar.theme-pink .toolbar-essentials a:hover { background-color: rgba(212, 51, 108, 0.08); }

.guide-toolbar.theme-sage     { border-bottom-color: #6b9080; }
.guide-toolbar.theme-sage .toolbar-nav a,
.guide-toolbar.theme-sage .toolbar-essentials a { color: #6b9080; border-color: #6b9080; }
.guide-toolbar.theme-sage .toolbar-nav a:hover,
.guide-toolbar.theme-sage .toolbar-essentials a:hover { background-color: rgba(107, 144, 128, 0.08); }

.guide-toolbar.theme-amber    { border-bottom-color: #d97706; }
.guide-toolbar.theme-amber .toolbar-nav a,
.guide-toolbar.theme-amber .toolbar-essentials a { color: #d97706; border-color: #d97706; }
.guide-toolbar.theme-amber .toolbar-nav a:hover,
.guide-toolbar.theme-amber .toolbar-essentials a:hover { background-color: rgba(217, 119, 6, 0.08); }

.guide-toolbar.theme-indigo   { border-bottom-color: #4338ca; }
.guide-toolbar.theme-indigo .toolbar-nav a,
.guide-toolbar.theme-indigo .toolbar-essentials a { color: #4338ca; border-color: #4338ca; }
.guide-toolbar.theme-indigo .toolbar-nav a:hover,
.guide-toolbar.theme-indigo .toolbar-essentials a:hover { background-color: rgba(67, 56, 202, 0.08); }

.guide-toolbar.theme-green    { border-bottom-color: #059669; }
.guide-toolbar.theme-green .toolbar-nav a,
.guide-toolbar.theme-green .toolbar-essentials a { color: #059669; border-color: #059669; }
.guide-toolbar.theme-green .toolbar-nav a:hover,
.guide-toolbar.theme-green .toolbar-essentials a:hover { background-color: rgba(5, 150, 105, 0.08); }

.guide-toolbar.theme-yellow   { border-bottom-color: #eab308; }
.guide-toolbar.theme-yellow .toolbar-nav a,
.guide-toolbar.theme-yellow .toolbar-essentials a { color: #eab308; border-color: #eab308; }
.guide-toolbar.theme-yellow .toolbar-nav a:hover,
.guide-toolbar.theme-yellow .toolbar-essentials a:hover { background-color: rgba(234, 179, 8, 0.08); }


/* Navigation arrows — plain text, blend with page background */
.toolbar-nav a {
  background: transparent;
  border-color: transparent;
  color: var(--c-title-bg);
}
/* Mobile toolbar */
@media (max-width: 600px) {
  .guide-toolbar {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 0;
  }
  .toolbar-nav,
  .toolbar-essentials {
    gap: 8px;
  }
  .toolbar-nav a,
  .toolbar-essentials a {
    padding: 3px 6px;
    font-size: 11px;
  }
}


/* ─── GUIDE NAVIGATION FOOTER ─────────────────────────────────────────────── */
/* Sequential navigation footer across all 18 guides. Sits at the bottom before
   page closing tags, providing previous/index/next links for guide traversal.
   Design: unified card with top border, flexbox layout, links styled to match
   the guide's overall link palette. */
.guide-nav {
  margin-top: 40px;
  padding-top: 20px;
  border-top: 1px solid var(--c-next-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 14px;
}
.guide-nav a {
  text-decoration: none;
  font-weight: 500;
  color: var(--c-title-bg);
}
.guide-nav a:hover {
  text-decoration: underline;
}


/* ─── TRAVEL ESSENTIALS TOOLBAR ─────────────────────────────────────────────── */
/* Quick access links to trip essentials: Trips, Lounges, Delta Routes, Packing.
   Styled with theme-colored border matching guide's inspiration section theme.
   Appears just before the guide navigation footer. */
.essentials-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 40px;
  padding: 16px 0;
  border-top: 2px solid var(--c-next-border);
  border-bottom: none;
  align-items: center;
  font-size: 13px;
}
.essentials-toolbar a {
  padding: 6px 12px;
  background-color: transparent;
  border: 1px solid var(--c-text-muted);
  border-radius: 4px;
  text-decoration: none;
  font-weight: 500;
  transition: all 0.2s ease;
}
.essentials-toolbar a:hover {
  background-color: var(--c-text-muted);
  color: white;
}

/* Theme-specific toolbar styling — border color matches guide theme */
.essentials-toolbar.theme-purple   { border-top-color: #7030A0; }
.essentials-toolbar.theme-teal     { border-top-color: #1c8a99; }
.essentials-toolbar.theme-coral    { border-top-color: #c85a54; }
.essentials-toolbar.theme-pink     { border-top-color: #d4336c; }
.essentials-toolbar.theme-sage     { border-top-color: #6b9080; }
.essentials-toolbar.theme-amber    { border-top-color: #d97706; }
.essentials-toolbar.theme-indigo   { border-top-color: #4338ca; }
.essentials-toolbar.theme-green    { border-top-color: #059669; }
.essentials-toolbar.theme-yellow   { border-top-color: #eab308; }

/* Back to top button */
.back-to-top {
  padding: 6px 12px;
  background-color: transparent;
  border: 1px solid var(--c-text-muted);
  border-radius: 4px;
  color: var(--c-text-muted);
  text-decoration: none;
  font-weight: 500;
  cursor: pointer;
  margin-left: auto;
  transition: all 0.2s ease;
}
.back-to-top:hover {
  background-color: var(--c-text-muted);
  color: white;
}

/* Essentials toolbar — shared across all guides */
.essentials {
  background: #f0ede8;
  border-bottom: 1px solid #d8d4cc;
  padding: 6px 0;
}
.essentials-inner {
  max-width: 940px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  align-items: center;
}
.essentials-link {
  font-size: 12px;
  color: #6a6660;
  text-decoration: none;
  padding: 3px 9px;
  border: 1px solid #d8d4cc;
  border-radius: 3px;
  background: none;
  white-space: nowrap;
  transition: color .15s, border-color .15s, background .15s;
}
.essentials-link:hover {
  color: #7a5c0e;
  border-color: #7a5c0e;
  background: rgba(138, 108, 26, 0.06);
}

/* ─── guides_index.html: warm-palette override (matches Trip Essentials) ── */
/* Apply class="index-page" to <body> in guides_index.html */
body.index-page {
  background: #f5f4f0;
  --c-purple:       #8a6c1a;
  --c-purple-pale:  var(--c-warm-bg);
  --c-purple-hover: #faefd8;
  --c-page-bg:      #f5f4f0;
  --c-card-bg:      #fff;
}
body.index-page .container { padding-bottom: 0; }

/* ─── guides_index.html: Banner ─────────────────────────────────────────── */
.index-banner {
  color: var(--c-purple);
  padding: 18px 0 14px;
  margin-bottom: 16px;
  border-bottom: 1px solid rgba(138,108,26,0.18);
}
.index-banner-title {
  font-size: 27px;
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.1;
  margin-bottom: 4px;
}
.index-banner-sub {
  font-size: 13px;
  color: #9a9890;
  font-weight: 400;
  letter-spacing: 0.01em;
}

/* ─── guides_index.html: Region sections ────────────────────────────────── */
body.index-page .glance-section {
  border-radius: 10px;
  overflow: hidden;
  padding: 0;
  margin-bottom: 16px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
body.index-page .glance-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 13px 20px 11px;
  margin-bottom: 0;
  border-bottom: 1px solid rgba(138,108,26,0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.idx-count {
  font-size: 11px;
  color: #b8ad9e;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

/* ─── guides_index.html: Guide cards ────────────────────────────────────── */
body.index-page .glance-day {
  border-radius: 0;
  padding: 11px 20px;
  border-bottom: 1px solid rgba(0,0,0,0.04);
  margin-bottom: 0;
}
body.index-page .glance-day:last-child { border-bottom: none; }
body.index-page .glance-day:hover { background: var(--c-purple-hover); }
body.index-page .glance-day-title {
  display: flex;
  align-items: center;
  gap: 14px;
  font-weight: normal;
  font-size: 14px;
}
.idx-num {
  font-size: 11px;
  font-weight: 600;
  color: #c4b49a;
  min-width: 22px;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.02em;
  flex-shrink: 0;
}
.idx-city {
  font-size: 14px;
  font-weight: 500;
  color: var(--c-purple);
  transition: color .15s;
}
body.index-page .glance-day:hover .idx-city { color: var(--c-purple); }
.index-banner-sub { font-size: 14px; margin-top: 4px; }
.index-banner-sub a { color: var(--c-purple); text-decoration: none; }
.index-footer {
  text-align: center;
  padding: 8px 0 40px;
  font-size: 12px;
  color: #aaa;
}
